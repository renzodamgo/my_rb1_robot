<?xml version="1.0"?>
<robot name="rb1_robot">

    
        <!-- Specify Gazebo color for the base_link -->
    <gazebo reference="base_link">
        <visual>
            <material> <!-- Black -->
                <ambient>0.0 0.0 0.0 1.0</ambient>
                <diffuse>0.0 0.0 0.0 1.0</diffuse>
                <specular>0.0 0.0 0.0 1.0</specular>
            </material>
        </visual>
    </gazebo>

    <!-- Gazebo friction and material properties for left_wheel -->
    <gazebo reference="left_wheel">
        <collision>
            <surface>
                <friction>
                    <ode>
                        <mu>1.0</mu>
                        <mu2>1.0</mu2>
                    </ode>
                </friction>
            </surface>
        </collision>
    </gazebo>

    <!-- Gazebo friction and material properties for right_wheel -->
    <gazebo reference="right_wheel">
        <collision>
            <surface>
                <friction>
                    <ode>
                        <mu>1.0</mu>
                        <mu2>1.0</mu2>
                    </ode>
                </friction>
            </surface>
        </collision>
    </gazebo>

    <!-- Gazebo friction and material properties for front_caster -->
    <gazebo reference="front_caster">
        <collision>
            <surface>
                <friction>
                    <ode>
                        <mu>0.0</mu>
                        <mu2>0.0</mu2>
                    </ode>
                </friction>
            </surface>
        </collision>
    </gazebo>

    <!-- Gazebo friction and material properties for back_caster -->
    <gazebo reference="back_caster">
        <collision>
            <surface>
                <friction>
                    <ode>
                        <mu>0.0</mu>
                        <mu2>0.0</mu2>
                    </ode>
                </friction>
            </surface>
        </collision>
    </gazebo>

        <!-- Define materials for visualization -->
    <material name="blue">
        <color rgba="0 0 1 1"/>
    </material>

    <material name="gray">
        <color rgba="0.40 0.40 0.40 1"/>
    </material>

    <material name="red">
        <color rgba="1 0 0 1"/>
    </material>

    <!-- Base footprint link -->
    <link name="base_footprint">
    </link>

    <joint name="base_link_plate_joint" type="fixed">
        <origin xyz="0 0 0.15" rpy="0 0 0"/>
        <parent link="base_footprint"/>
        <child link="base_link"/>
    </joint>

  <link name="base_link">
    <inertial>
        <mass value="20.0"/>
        <inertia ixx="0.4625" ixy="0" ixz="0" iyy="0.4625" iyz="0" izz="0.625"/>
    </inertial>
    <visual>
      <geometry>
          <cylinder radius="0.25" length="0.3"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
          <cylinder radius="0.25" length="0.3"/>
      </geometry>
    </collision>
  </link>

  <link name="left_wheel">
    <inertial>
        <mass value="2.0"/>
        <inertia ixx="0.000625" ixy="0" ixz="0" iyy="0.000729" iyz="0" izz="0.000729"/>
    </inertial>
      <visual>
      <origin xyz="0 0 0" rpy="-1.5708 0 0"/>
      <geometry>
          <cylinder radius="0.025" length="0.05"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
        <origin xyz="0 0 0" rpy="-1.5708 0 0"/>
      <geometry>
          <cylinder radius="0.025" length="0.05"/>
      </geometry>
    </collision>   
  </link>

    <joint name="base_link_left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel"/>
        <origin xyz="0 0.2 -0.15" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

  <link name="right_wheel">
    <inertial>
        <mass value="2.0"/>
        <inertia ixx="0.000625" ixy="0" ixz="0" iyy="0.000729" iyz="0" izz="0.000729"/>
    </inertial>
    <visual>
        <origin xyz="0 0 0" rpy="-1.5708 0 0"/>
      <geometry>
          <cylinder radius="0.025" length="0.05"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
        <origin xyz="0 0 0" rpy="-1.5708 0 0"/>
      <geometry>
          <cylinder radius="0.025" length="0.05"/>
      </geometry>
    </collision>   
  </link>

    <joint name="base_link_right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel"/>
        <origin xyz="0 -0.2 -0.15" rpy="0 0 0"/> 
        <axis xyz="0 1 0"/>
    </joint>

  <link name="front_caster">
    <inertial>
        <mass value="0.3"/>
        <inertia ixx="0.000075" ixy="0" ixz="0" iyy="0.000075" iyz="0" izz="0.000075"/>
    </inertial>
    <visual>
    <geometry>
            <sphere radius="0.025"/>
        </geometry>
        <material name="red"/>
    </visual>
    <collision>
        <geometry>
            <sphere radius="0.025"/>
        </geometry>
    </collision>
  </link>

    <joint name="base_link_front_caster_joint" type="fixed">
        <origin xyz="-0.1 0.0 -0.15" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="front_caster"/>
    </joint>

  <link name="back_caster">
    <inertial>
        <mass value="0.3"/>
        <inertia ixx="0.000075" ixy="0" ixz="0" iyy="0.000075" iyz="0" izz="0.000075"/>
    </inertial>
    <visual>
    <geometry>
            <sphere radius="0.025"/>
        </geometry>
        <material name="red"/>
    </visual>
    <collision>
        <geometry>
            <sphere radius="0.025"/>
        </geometry>
    </collision>
  </link>

      <joint name="base_link_back_caster_joint" type="fixed">
        <origin xyz="0.1 0.0 -0.15" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="back_caster"/>
    </joint>
    
    <!-- Link representing the front laser scanner -->
    <!--For this robot, the laser is not visible, so we won't define a body for it. -->
    <link name="front_laser">
        <inertial>
            <mass value="0.4"/>
            <inertia ixx="0.000173" ixy="0" ixz="0" iyy="0.000267" iyz="0" izz="0.000333"/>
        </inertial>
        <visual>
            <geometry>
                <cylinder radius="0.035" length="0.04"/>
            </geometry>
            <material name="red"/>
        </visual>
        
        <collision>
            <geometry>
                <cylinder radius="0.035" length="0.04"/>
            </geometry>
        </collision>
    </link>

    <!-- Joint connecting base_link and front_laser -->
    <joint name="base_link_front_laser_joint" type="fixed">
        <origin xyz="0.25 0.0 0.075" rpy="3.1416 0 0"/>
        <parent link="base_link"/>
        <child link="front_laser"/>
    </joint>
</robot>