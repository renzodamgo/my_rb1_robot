<?xml version="1.0"?>
<robot name="rb1_robot">

    
    <gazebo reference="front_caster">
        <mu1>0.0</mu1>
        <mu2>0.0</mu2>
    </gazebo>
    <gazebo reference="back_caster">
        <mu1>0.0</mu1>
        <mu2>0.0</mu2>
    </gazebo>

        <!-- Define materials for visualization -->
    <material name="blue">
        <color rgba="0 0 1 1"/>
    </material>

    <material name="gray">
        <color rgba="0.40 0.40 0.40 1"/>
    </material>

    <material name="red">
        <color rgba="1 0 0 1"/>
    </material>

    <!-- Base footprint link -->
    <link name="base_footprint">
    </link>

    <joint name="base_link_plate_joint" type="fixed">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <parent link="base_footprint"/>
        <child link="base_link"/>
    </joint>

  <link name="base_link">
    <visual>
      <geometry>
          <cylinder radius="0.25" length="0.3"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
          <cylinder radius="0.25" length="0.3"/>
      </geometry>
    </collision>
  </link>

  <link name="left_wheel">
      <visual>
      <origin xyz="0 0 0" rpy="-1.5708 0 0"/>
      <geometry>
          <cylinder radius="0.025" length="0.05"/>
      </geometry>
    </visual>
    <collision>
        <origin xyz="0 0 0" rpy="-1.5708 0 0"/>
      <geometry>
          <cylinder radius="0.025" length="0.05"/>
      </geometry>
    </collision>   
  </link>

    <joint name="base_link_left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel"/>
        <origin xyz="0 0.2 -0.15" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

  <link name="right_wheel">
    <visual>
        <origin xyz="0 0 0" rpy="-1.5708 0 0"/>
      <geometry>
          <cylinder radius="0.025" length="0.05"/>
      </geometry>
    </visual>
    <collision>
        <origin xyz="0 0 0" rpy="-1.5708 0 0"/>
      <geometry>
          <cylinder radius="0.025" length="0.05"/>
      </geometry>
    </collision>   
  </link>

    <joint name="base_link_right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel"/>
        <origin xyz="0 -0.2 -0.15" rpy="0 0 0"/> 
        <axis xyz="0 1 0"/>
    </joint>

  <link name="front_caster">
    <visual>
    <geometry>
            <sphere radius="0.025"/>
        </geometry>
    </visual>
    <collision>
        <geometry>
            <sphere radius="0.025"/>
        </geometry>
    </collision>
  </link>

    <joint name="base_link_front_caster_joint" type="fixed">
        <origin xyz="-0.1 0.0 -0.15" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="front_caster"/>
    </joint>

  <link name="back_caster">
    <visual>
    <geometry>
            <sphere radius="0.025"/>
        </geometry>
    </visual>
    <collision>
        <geometry>
            <sphere radius="0.025"/>
        </geometry>
    </collision>
  </link>

      <joint name="base_link_back_caster_joint" type="fixed">
        <origin xyz="0.1 0.0 -0.15" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="back_caster"/>
    </joint>
    
    <!-- Link representing the front laser scanner -->
    <!--For this robot, the laser is not visible, so we won't define a body for it. -->
    <link name="front_laser">
    </link>

    <!-- Joint connecting base_link and front_laser -->
    <!-- TO DO: Set correct joint type -->
    <joint name="base_link_front_laser_joint" type="fixed">
        <origin xyz="0.25 0.0 0.075" rpy="3.1416 0 0"/>
        <parent link="base_link"/>
        <child link="front_laser"/>
    </joint>
</robot>