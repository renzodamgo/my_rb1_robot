<?xml version="1.0"?>
<robot name="my_rb1_robot">
    <gazebo reference="caster_front">
        <mu1>0.0</mu1>
        <mu2>0.0</mu2>
    </gazebo>
    <gazebo reference="caster_back">
        <mu1>0.0</mu1>
        <mu2>0.0</mu2>
    </gazebo>

  <link name="base_link">
    <visual>
      <geometry>
          <cylinder radius="0.05" length="0.3"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
          <cylinder radius="0.05" length="0.2"/>
      </geometry>
    </collision>
  </link>

  <link name="wheel_left">
      <visual>
      <origin xyz="0 -0.2 -0.15" rpy="0 0 0"/>
      <geometry>
          <cylinder radius="0.005" length="0.005"/>
      </geometry>
    </visual>
    <collision>
            <origin xyz="0 -0.2 -0.15" rpy="0 0 0"/>
      <geometry>
          <cylinder radius="0.005" length="0.005"/>
      </geometry>
    </collision>   
  </link>


  <link name="wheel_right">
        <visual>
      <origin xyz="0 0.2 -0.15" rpy="0 0 0"/>
      <geometry>
          <cylinder radius="0.005" length="0.005"/>
      </geometry>
    </visual>
    <collision>
            <origin xyz="0 0.2 -0.15" rpy="0 0 0"/>
      <geometry>
          <cylinder radius="0.005" length="0.005"/>
      </geometry>
    </collision>   
  </link>

  <link name="caster_front">
    <visual>
    <origin xyz="-0.1 0.0 -0.15" rpy="0 0 0"/>
    <geometry>
            <sphere radius="0.025">
        <geometry/>
    </visual>
    <collision>
    <origin xyz="-0.1 0.0 -0.15" rpy="0 0 0"/>
        <geometry>
            <sphere radius="0.025">
        <geometry/>
    </collision>
  </link>

  <link name="caster_back">
    <visual>
    <origin xyz="0.1 0.0 -0.15" rpy="0 0 0"/>
    <geometry>
            <sphere radius="0.025">
        <geometry/>
    </visual>
    <collision>
    <origin xyz="0.1 0.0 -0.15" rpy="0 0 0"/>
        <geometry>
            <sphere radius="0.025">
        <geometry/>
    </collision>
  </link>

</robot>